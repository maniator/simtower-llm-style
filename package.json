{
  "name": "tower-tycoon",
  "version": "1.0.0",
  "description": "Tower Tycoon — a browser-native SimTower clone in TypeScript",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.singlefile.config.ts",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "screenshots": "vite build && node scripts/serve-and-shoot.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^28.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "excalibur": "^0.32.0"
  }
}
